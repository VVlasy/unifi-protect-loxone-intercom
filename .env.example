#==============================================================================
# Copy to .env and fill in the four PROTECT_* values. That's all a normal setup
# needs — everything else has a sensible default baked into the image, and the
# internal secrets (ARI password, webhook token) are generated automatically.
#
#   cp .env.example .env   &&   docker compose up -d --build
#
# The OPTIONAL section at the bottom is for tuning and extra features; leave it
# untouched unless a setup step tells you to.
#==============================================================================

# --- Required: UniFi Protect -------------------------------------------------
# RTSPS "share" link: doorbell > Settings > Advanced > RTSP. (rtspx://IP:7441/KEY)
PROTECT_CAMERA_PATH=rtspx://192.168.1.10:7441/CHANGEME

# Base URL of the Protect controller (UDM/Cloud Key). Usually https://<protect-ip>
PROTECT_BASE=https://192.168.1.10

# Integration API key: Protect > Settings > Control Plane > Integrations > Create.
PROTECT_API_KEY=CHANGEME

# Doorbell camera id, from the URL: https://<ip>/protect/devices/<CAMERA_ID>
CAMERA_ID=CHANGEME


#==============================================================================
# OPTIONAL — defaults are fine for most setups. Uncomment only what you need.
#==============================================================================

# --- SIP extension (the Loxone "Audio username") -----------------------------
# Default 9900. If you expose SIP to the internet, set this to a longer,
# non-obvious number and use the same value as Loxone's "Audio username".
#DOORBELL_EXTENSION=9900

# --- Remote access (calling in from OFF the LAN, no VPN) ----------------------
# Leave blank for LAN/VPN-only (the default). To accept calls from the internet,
# set your PUBLIC name/IP (as it resolves from THIS host) and list your private
# subnets so on-net clients stay on the private path. Also port-forward 5060/udp
# and 10000-10200/udp, and raise DOORBELL_EXTENSION above. See ADVANCED.md.
#SIP_EXTERNAL_ADDRESS=your-public-name.example.com
#SIP_LOCAL_NET=192.168.1.0/24,192.168.2.0/24

# --- Video (MJPEG served to Loxone on :1984) ---------------------------------
#MJPEG_FPS=10
#MJPEG_SCALE_W=1280
#MJPEG_QUALITY=8
# Rotate the feed for consumers: ""=none, 1=90deg CW, 2=90deg CCW, "1,1"=180.
#MJPEG_TRANSPOSE=
# Basic auth on the video stream (set BOTH to enable; plain HTTP, keep LAN/VPN-only).
# Loxone URL then: http://<user>:<pass>@<host>:1984/?action=stream
#MJPEG_AUTH_USER=
#MJPEG_AUTH_PASS=

# --- Echo / ducking (voice-gated attenuation of the caller's downlink) -------
#   DUCK_ATTEN_DB: VOLUME(TX) linear divisor, NOT dB (-5=/5 ... -30=near silent).
#   DUCK_HOLD_MS:  stay ducked this long after talk stops (covers word gaps).
#DUCK_TALK_THRESHOLD=180
#DUCK_ATTEN_DB=-30
#DUCK_HOLD_MS=900

# --- Camera landscape fix (experimental, off by default) ---------------------
# Force a portrait-locked UniFi doorbell to output landscape, at the source.
# Pokes undocumented camera firmware internals — see README section 9 and
# ADVANCED.md before enabling. Requires camera SSH enabled on the UDM.
#ROTATION_FIX_ENABLED=0
#CAMERA_IP=192.168.1.23
#CAMERA_SSH_PASS=CHANGEME-camera-recovery-code
