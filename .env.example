#==============================================================================
# Copy to .env and fill in. Everything the image needs is here.
#==============================================================================

# --- UniFi Protect ----------------------------------------------------------
# RTSPS "share" link from Protect: doorbell > Settings > Advanced > RTSP.
# Looks like rtspx://<protect-ip>:7441/<streamkey>
PROTECT_CAMERA_PATH=rtspx://192.168.1.10:7441/CHANGEME

# Base URL of the Protect controller (UDM/Cloud Key). Usually https://<protect-ip>
PROTECT_BASE=https://192.168.1.10

# Protect Integration API key:
#   Protect > Settings > Control Plane > Integrations > create API key
PROTECT_API_KEY=CHANGEME

# Doorbell camera id - from the URL when you open the camera in Protect:
#   https://<ip>/protect/devices/<CAMERA_ID>
CAMERA_ID=CHANGEME

# --- Asterisk / ARI ---------------------------------------------------------
ARI_URL=http://127.0.0.1:8088
ARI_USER=doorbellari
ARI_PASS=change-me-to-a-long-random-string
APP_NAME=doorbellbridge

# RTP port the bridge listens on for audio coming FROM Asterisk (localhost only)
RX_PORT_FROM_ASTERISK=9999

# --- Doorbell audio (served by go2rtc, do not change) -----------------------
DOORBELL_RTSP_AUDIO=rtsp://127.0.0.1:8554/unifi_doorbell?audio

# --- Ringing SIP phones (NOT used for Loxone; leave the dummy in place) -----
# Loxone is not a registered SIP phone, so we don't ring it through Asterisk.
# The bridge code requires this var to be set, so keep a placeholder.
RING_ENDPOINTS=PJSIP/101
DOORBELL_CALLERID=Doorbell <9900>
RING_TIMEOUT_MS=45000
NO_ANSWER_TIMEOUT_MS=30000
# Keep >= 3000ms; lower values cause stream latency (per the bridge author).
RING_DELAY_MS=3500
ENABLE_AGC=1

# --- Half-duplex ducking (local patch, see patches/duck-soft-attenuation.js) -
# Voice-gated ducker that attenuates the caller's downlink while they talk, to kill
# echo. Make it "sticky" to avoid echo leaking in the gaps between words:
#   DUCK_TALK_THRESHOLD: talk-detect sensitivity; LOWER = engages sooner on onset.
#   DUCK_ATTEN_DB: Asterisk VOLUME(TX), a LINEAR divisor (NOT dB); negative N divides
#     amplitude by N (-5=/5 weak ... -30=/30 near silent while talking).
#   DUCK_HOLD_MS: stay ducked this long after talk stops (covers inter-word pauses).
DUCK_TALK_THRESHOLD=180
DUCK_ATTEN_DB=-30
DUCK_HOLD_MS=900

# --- Video MJPEG (mjpg-streamer, fed by continuous ffmpeg transcode) ---------
# Loxone video URL: http://<host>:8080/?action=stream (or ?action=snapshot).
# Always-warm transcode -> instant open. Port is fixed at 8080 in supervisord.conf.
MJPEG_FPS=10
MJPEG_SCALE_W=1280
MJPEG_QUALITY=8
# Rotation: ""=none, 1=90deg clockwise, 2=90deg counter-clockwise, "1,1"=180.
MJPEG_TRANSPOSE=
MJPEG_PORT=1984
# Basic auth on the video stream (set BOTH user+pass to enable; empty = no auth).
# Plain HTTP -> keep 8080 LAN/VPN-only. Loxone URL: http://<user>:<pass>@<host>:8080/?action=stream
MJPEG_AUTH_USER=
MJPEG_AUTH_PASS=change-me

# --- Ring webhook (Protect -> bridge). Optional for the Loxone-only flow. ----
WEBHOOK_BIND=0.0.0.0
WEBHOOK_PORT=3000
WEBHOOK_PATH=/doorbell/ring
WEBHOOK_TOKEN=change-me-too

# --- Camera rotation fix: force doorbell to LANDSCAPE-UPRIGHT (optional) -----
# UniFi doorbells hardcode a 90deg portrait ("hallway") rotation Protect cannot
# disable. When enabled, camera-rotation-watchdog.sh SSHes to the camera every
# ROTATION_CHECK_INTERVAL s and (re)applies an LD_PRELOAD hook (hallwayMode=
# HALLWAY_VALUE; 0 = disabled = landscape) + ISP flip+mirror (=180, corrects the
# upside-down native landscape), re-applying after any camera reboot.
#
# PREREQUISITE: enable camera SSH on the UDM first:
#   /etc/unifi-protect/config.json -> {"enableSsh": true} ; restart unifi-protect
# Camera login: user 'ubnt' + the camera's Recovery Code.
# Leave ROTATION_FIX_ENABLED=0 to keep the doorbell stock (portrait).
ROTATION_FIX_ENABLED=0
CAMERA_IP=192.168.1.23
CAMERA_SSH_PASS=CHANGEME-camera-recovery-code
HALLWAY_VALUE=0
ISP_FLIP=1
ISP_MIRROR=1
ROTATION_CHECK_INTERVAL=30
